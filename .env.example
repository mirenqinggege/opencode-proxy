# OpenCode Configuration

# Optional: Proxy server (http://proxy.abc.com:port)
OPENCODE_PROXY=

# API key for OpenCode service
OPENCODE_API_KEY=your-api-key-here

# Auth token for incoming proxy requests (clients set ANTHROPIC_AUTH_TOKEN=this)
# Leave empty to disable authentication (not recommended for public deployments)
AUTH_TOKEN=your-auth-token-here

# Model mapping for routes
OPUS_MAP_MODEL=kimi-k2.6
SONNET_MAP_MODEL=glm-5.1
HAIKU_MAP_MODEL=minimax-m2.5

# Optional: Override server ports
# OPENCODE_HOST=0.0.0.0
# OPENCODE_PORT=4000
# OPENCODE_WEB_PORT=8082
